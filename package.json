{
  "name": "minitickets",
  "version": "1.10.44",
  "description": "MiniTickets - lightweight bilingual workspace ticketing",
  "scripts": {
    "dev": "prisma generate && next dev",
    "build": "prisma generate && next build",
    "start": "next start",
    "lint": "prisma generate && eslint .",
    "db:push": "prisma db push && prisma generate",
    "db:seed": "prisma generate && node --experimental-strip-types prisma/seed.ts",
    "db:backfill-assignments": "node --experimental-strip-types scripts/backfill-ticket-assignments.ts",
    "db:backfill-payment-method-snapshots": "node --experimental-strip-types scripts/backfill-ticket-payment-method-snapshots.ts",
    "db:dedupe-auto-closed-activities": "node --experimental-strip-types scripts/dedupe-auto-closed-activities.ts",
    "db:studio": "prisma studio",
    "bootstrap:admin": "node --experimental-strip-types scripts/bootstrap-admin.ts",
    "email:welcome": "node --experimental-strip-types scripts/resend-welcome-email.ts",
    "email:invite": "node --experimental-strip-types scripts/send-invite-email.ts",
    "events:process": "node --experimental-strip-types scripts/process-ticket-reminders.ts"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/iandorsey00/minitickets.git"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "type": "module",
  "bugs": {
    "url": "https://github.com/iandorsey00/minitickets/issues"
  },
  "homepage": "https://github.com/iandorsey00/minitickets#readme",
  "engines": {
    "node": "^20.19 || ^22.12 || ^24.0"
  },
  "dependencies": {
    "@fontsource-variable/noto-sans-sc": "^5.2.10",
    "@fontsource/inter": "^5.2.8",
    "@prisma/adapter-better-sqlite3": "^7.8.0",
    "@prisma/client": "^7.8.0",
    "bcryptjs": "^3.0.3",
    "better-sqlite3": "^12.8.0",
    "dotenv": "^17.4.0",
    "lucide-react": "^1.7.0",
    "next": "^16.2.4",
    "prisma": "^7.8.0",
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "zod": "^4.3.6"
  },
  "overrides": {
    "@hono/node-server": "1.19.13",
    "postcss": "8.5.10"
  },
  "devDependencies": {
    "@types/node": "^25.5.2",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "eslint": "^9.39.4",
    "eslint-config-next": "^16.2.2",
    "typescript": "^5.9.3"
  }
}
