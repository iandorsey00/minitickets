APP_DOMAIN=minitickets.iandorsey.com
APP_DIR=/var/www/minitickets/app
APP_USER=www-data
APP_GROUP=www-data
APP_PORT=3010
ENV_FILE=/var/www/minitickets/.env.production
NODE_BIN_DIR=/opt/homebrew/opt/node@24/bin
SERVICE_NAME=minitickets
CLIENT_MAX_BODY_SIZE=20M
BACKUP_SERVICE_NAME=minitickets-backup
BACKUP_USER=root
BACKUP_GROUP=root
BACKUP_ROOT=/var/backups/minitickets
RETENTION_DAYS=14
BACKUP_PREFIX=minitickets
INCLUDE_ENV_FILE=0
BACKUP_ON_CALENDAR="*-*-* 03:30:00"
REMINDER_SERVICE_NAME=minitickets-reminders
REMINDER_USER=www-data
REMINDER_GROUP=www-data
REMINDER_ON_CALENDAR="*:0/5"
