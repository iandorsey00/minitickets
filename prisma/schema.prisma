generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
}

enum UserRole {
  ADMIN
  USER
}

enum Locale {
  ZH_CN
  EN
}

enum ThemePreference {
  SYSTEM
  LIGHT
  DARK
}

enum AccentColor {
  BLUE
  CYAN
  TEAL
  GREEN
  LIME
  YELLOW
  ORANGE
  RED
  PINK
  PURPLE
}

enum WorkspaceRole {
  ADMIN
  MEMBER
}

model User {
  id                  String                @id @default(cuid())
  email               String                @unique
  passwordHash        String
  displayName         String
  role                UserRole              @default(USER)
  locale              Locale                @default(ZH_CN)
  timeZone            String                @default("America/Los_Angeles")
  themePreference     ThemePreference       @default(SYSTEM)
  accentColor         AccentColor           @default(BLUE)
  emailMfaEnabled     Boolean               @default(false)
  isActive            Boolean               @default(true)
  createdAt           DateTime              @default(now())
  updatedAt           DateTime              @updatedAt
  memberships         WorkspaceMembership[]
  requestedTickets    Ticket[]              @relation("RequesterTickets")
  assignedTickets     Ticket[]              @relation("AssigneeTickets")
  comments            TicketComment[]
  activities          TicketActivity[]      @relation("ActorActivities")
  uploadedAttachments TicketAttachment[]    @relation("UploadedAttachments")
  createdPaymentMethods PaymentMethod[]     @relation("CreatedPaymentMethods")
  createdTicketEvents  TicketEvent[]        @relation("CreatedTicketEvents")
  notifications       Notification[]
  sessions            Session[]
  authAccounts        AuthAccount[]
  passwordSetupTokens PasswordSetupToken[]
  loginEmailChallenges LoginEmailChallenge[]
}

model Workspace {
  id            String                @id @default(cuid())
  slug          String                @unique
  ticketPrefix  String?               @unique
  name          String
  description   String?
  isArchived    Boolean               @default(false)
  createdAt     DateTime              @default(now())
  updatedAt     DateTime              @updatedAt
  memberships   WorkspaceMembership[]
  paymentMethods PaymentMethod[]
  tickets       Ticket[]
}

model WorkspaceMembership {
  id          String        @id @default(cuid())
  userId      String
  workspaceId String
  role        WorkspaceRole @default(MEMBER)
  createdAt   DateTime      @default(now())
  user        User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  workspace   Workspace     @relation(fields: [workspaceId], references: [id], onDelete: Cascade)

  @@unique([userId, workspaceId])
}

model StatusDefinition {
  id        String   @id @default(cuid())
  key       String   @unique
  labelZh   String
  labelEn   String
  sortOrder Int      @default(0)
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  tickets    Ticket[]
}

model PriorityDefinition {
  id        String   @id @default(cuid())
  key       String   @unique
  labelZh   String
  labelEn   String
  sortOrder Int      @default(0)
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  tickets    Ticket[]
}

model CategoryDefinition {
  id        String   @id @default(cuid())
  key       String   @unique
  labelZh   String
  labelEn   String
  sortOrder Int      @default(0)
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  tickets    Ticket[]
}

model Ticket {
  id          String               @id @default(cuid())
  serialNumber Int
  ticketNumber String             @unique
  title       String
  description String
  dueDate     DateTime?
  resolvedAt  DateTime?
  paymentLabel String?
  paymentLast4 String?
  createdAt   DateTime            @default(now())
  updatedAt   DateTime            @updatedAt
  workspaceId String
  parentTicketId String?
  requesterId String
  assigneeId  String?
  statusId    String
  priorityId  String
  categoryId  String
  workspace   Workspace           @relation(fields: [workspaceId], references: [id], onDelete: Restrict)
  parentTicket Ticket?            @relation("TicketChildren", fields: [parentTicketId], references: [id], onDelete: SetNull)
  childTickets Ticket[]           @relation("TicketChildren")
  requester   User                @relation("RequesterTickets", fields: [requesterId], references: [id], onDelete: Restrict)
  assignee    User?               @relation("AssigneeTickets", fields: [assigneeId], references: [id], onDelete: SetNull)
  status      StatusDefinition    @relation(fields: [statusId], references: [id], onDelete: Restrict)
  priority    PriorityDefinition  @relation(fields: [priorityId], references: [id], onDelete: Restrict)
  category    CategoryDefinition  @relation(fields: [categoryId], references: [id], onDelete: Restrict)
  comments    TicketComment[]
  activities  TicketActivity[]
  attachments TicketAttachment[]
  paymentMethods TicketPaymentMethod[]
  notifications Notification[]
  events      TicketEvent[]

  @@index([workspaceId, createdAt])
  @@index([parentTicketId])
  @@index([requesterId, createdAt])
  @@index([assigneeId, createdAt])
  @@unique([workspaceId, serialNumber])
}

model TicketComment {
  id        String   @id @default(cuid())
  ticketId   String
  authorId   String
  body      String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  ticket     Ticket   @relation(fields: [ticketId], references: [id], onDelete: Cascade)
  author     User     @relation(fields: [authorId], references: [id], onDelete: Restrict)
}

model TicketActivity {
  id          String   @id @default(cuid())
  ticketId     String
  actorUserId  String?
  eventType   String
  messageZh   String
  messageEn   String
  metadata    Json?
  createdAt   DateTime @default(now())
  ticket      Ticket   @relation(fields: [ticketId], references: [id], onDelete: Cascade)
  actor       User?    @relation("ActorActivities", fields: [actorUserId], references: [id], onDelete: SetNull)

  @@index([ticketId, createdAt])
}

model TicketAttachment {
  id              String   @id @default(cuid())
  ticketId        String
  uploadedByUserId String
  originalName    String
  storedName      String
  mimeType        String?
  fileSizeBytes   Int
  filePath        String
  createdAt       DateTime @default(now())
  ticket          Ticket   @relation(fields: [ticketId], references: [id], onDelete: Cascade)
  uploadedBy      User     @relation("UploadedAttachments", fields: [uploadedByUserId], references: [id], onDelete: Restrict)

  @@index([ticketId, createdAt])
}

model Notification {
  id          String   @id @default(cuid())
  userId      String
  ticketId     String?
  eventType   String
  titleZh     String
  titleEn     String
  bodyZh      String?
  bodyEn      String?
  isRead      Boolean  @default(false)
  browserDeliveredAt DateTime?
  createdAt   DateTime @default(now())
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  ticket      Ticket?  @relation(fields: [ticketId], references: [id], onDelete: Cascade)

  @@index([userId, createdAt])
  @@index([userId, browserDeliveredAt, createdAt])
}

model TicketEvent {
  id              String               @id @default(cuid())
  ticketId        String
  createdByUserId String
  title           String
  notes           String?
  scheduledFor    DateTime
  createdAt       DateTime             @default(now())
  updatedAt       DateTime             @updatedAt
  ticket          Ticket               @relation(fields: [ticketId], references: [id], onDelete: Cascade)
  createdBy       User                 @relation("CreatedTicketEvents", fields: [createdByUserId], references: [id], onDelete: Restrict)
  reminders       TicketEventReminder[]

  @@index([ticketId, scheduledFor])
}

model TicketEventReminder {
  id            String    @id @default(cuid())
  eventId       String
  offsetMinutes Int
  sentAt        DateTime?
  createdAt     DateTime  @default(now())
  event         TicketEvent @relation(fields: [eventId], references: [id], onDelete: Cascade)

  @@unique([eventId, offsetMinutes])
  @@index([sentAt])
}

model Session {
  id           String   @id @default(cuid())
  userId       String
  tokenHash    String   @unique
  expiresAt    DateTime
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, expiresAt])
}

model AuthAccount {
  id                String   @id @default(cuid())
  userId            String
  provider          String
  providerAccountId String
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt
  user              User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model PasswordSetupToken {
  id        String   @id @default(cuid())
  userId     String
  tokenHash  String   @unique
  expiresAt  DateTime
  usedAt     DateTime?
  createdAt  DateTime @default(now())
  user       User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, expiresAt])
}

model AuthRateLimit {
  id              String   @id @default(cuid())
  action          String
  key             String
  attempts        Int      @default(0)
  windowStartedAt DateTime @default(now())
  blockedUntil    DateTime?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  @@unique([action, key])
}

model LoginEmailChallenge {
  id         String   @id @default(cuid())
  userId      String
  tokenHash   String   @unique
  codeHash    String
  expiresAt   DateTime
  usedAt      DateTime?
  createdAt   DateTime @default(now())
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, expiresAt])
}

model PaymentMethod {
  id          String   @id @default(cuid())
  workspaceId String
  createdByUserId String
  label       String
  last4       String
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  createdBy   User     @relation("CreatedPaymentMethods", fields: [createdByUserId], references: [id], onDelete: Cascade)
  workspace   Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  tickets     TicketPaymentMethod[]

  @@unique([workspaceId, label, last4])
  @@index([workspaceId])
}

model TicketPaymentMethod {
  id              String        @id @default(cuid())
  ticketId         String
  paymentMethodId  String
  createdAt        DateTime      @default(now())
  ticket           Ticket        @relation(fields: [ticketId], references: [id], onDelete: Cascade)
  paymentMethod    PaymentMethod @relation(fields: [paymentMethodId], references: [id], onDelete: Cascade)

  @@unique([ticketId, paymentMethodId])
  @@index([paymentMethodId])
}
